# Azure App Service application settings (example)
# Paste these key/value pairs in Azure Portal -> App Service -> Configuration.

DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/carbon_db?sslmode=require
ELECTRICITYMAPS_KEY=<required>
OPENAI_API_KEY=<optional>
CORS_ORIGINS=https://<your-vercel-app>.vercel.app
PYTHONPATH=.
WEBSITES_PORT=8000
