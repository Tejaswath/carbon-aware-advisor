ELECTRICITYMAPS_KEY=your_electricitymaps_key
OPENAI_API_KEY=your_openai_key_optional
ELECTRICITYMAPS_BASE_URL=https://api.electricitymaps.com
CORS_ORIGINS=http://localhost:3000
GRID_ZONE=SE-SE3
CARBON_THRESHOLD=40
FORECAST_WINDOW_HOURS=24
REQUEST_TIMEOUT_SECONDS=10
CACHE_TTL_SECONDS=300
RETRY_MAX_ATTEMPTS=3
ROUTING_CANDIDATE_ZONES=SE-SE3,SE-SE1,SE-SE2,SE-SE4,NO-NO1,FI
MAX_ROUTING_CANDIDATES=6
CANDIDATE_FETCH_MODE=sequential
PARALLEL_FETCH_WORKERS=3
ENABLE_POSTPONE_FORECAST_RECOMMENDATION=false
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=
LANGGRAPH_DB_PATH=./langgraph_checkpoints.db
